.container {
  padding: 20rpx 20rpx calc(130rpx + env(safe-area-inset-bottom));
  min-height: 100vh;
  box-sizing: border-box;
  background: linear-gradient(180deg, #F1F8E9 0%, #DCEDC8 100%);
}

.header {
  padding: 40rpx 20rpx;
  text-align: left;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #1B3D2B;
}

.content {
  padding: 20rpx 0;
}

.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.card-desc {
  display: block;
  font-size: 28rpx;
  color: #999999;
}

.map-card {
  padding: 0;
  overflow: hidden;
}

.map-card-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 30rpx 0 30rpx;
}

.map-card .card-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  padding: 0;
  margin-bottom: 0;
}

.map-expand-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  flex-shrink: 0;
  background-color: transparent;
  transition: background-color 120ms ease-out;
}

.map-expand-btn-hover {
  background-color: rgba(0, 0, 0, 0.08);
}

.map-expand-icon {
  font-size: 40rpx;
  color: #999999;
  line-height: 1;
}

.map-container {
  width: 100%;
  height: 500rpx;
  margin-top: 20rpx;
}

.daily-bird-inner {
  background-color: #F1F8E9;
  border-radius: 12rpx;
  padding: 20rpx;
}

.daily-bird-card .bd-card-row {
  display: flex;
  flex-direction: row;
  align-items: stretch;
}

.daily-bird-card .bd-image {
  width: 180rpx;
  height: 250rpx;
  border-radius: 12rpx;
  background-color: #E0E0E0;
  flex-shrink: 0;
  overflow: hidden;
}

.daily-bird-card .bd-image-img {
  width: 100%;
  height: 100%;
  display: block;
}

.daily-bird-card .bd-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  margin-left: 20rpx;
}

.daily-bird-card .bd-info-top {
  display: flex;
  flex-direction: column;
}

.daily-bird-card .bd-name {
  font-family: "宋体", SimSun, serif;
  font-size: 45rpx;
  font-weight: 600;
  line-height: 1.2;
  color: #1B3D2B;
}

.daily-bird-card .bd-sci {
  font-style: italic;
  font-size: 25rpx;
  line-height: 1.2;
  color: #999999;
  margin-top: 2rpx;
}

.daily-bird-card .bd-features {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.daily-bird-card .bd-feature {
  font-size: 24rpx;
  line-height: 1.4;
  color: #888888;
}

.daily-bird-card .bd-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.daily-bird-card .bd-tag {
  height: 50rpx;
  padding: 0 26rpx;
  border-radius: 25rpx;
  background-color: rgba(27, 61, 43, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
}

.daily-bird-card .bd-tag-text {
  font-size: 28rpx;
  color: #1B3D2B;
}

/* 当季常见鸟类轮播 */
.season-bird-card {
  padding: 0;
  overflow: hidden;
}

.season-bird-card .season-bird-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 0;
}

.season-bird-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 30rpx 20rpx 30rpx;
}

.season-bird-link-top {
  font-size: 32rpx;
  font-weight: 300;
  color: #333333;
  text-align: right;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.season-bird-gradient {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 50%;
  background: linear-gradient(to bottom, transparent 0%, rgba(0, 0, 0, 0.65) 100%);
  pointer-events: none;
}

.season-bird-overlay-bottom {
  position: absolute;
  bottom: 24rpx;
  left: 30rpx;
  right: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  z-index: 2;
}

.season-bird-name {
  font-family: "宋体", SimSun, serif;
  color: #ffffff;
  font-size: 50rpx;
  font-weight: 600;
  line-height: 1.2;
}

.season-bird-detail-link {
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 300;
  padding-bottom: 4rpx;
}

.season-bird-image-wrapper {
  position: relative;
  width: 100%;
  height: 500rpx;
  margin-top: 0;
}

.season-bird-image {
  width: 100%;
  height: 100%;
  background-color: #E0E0E0;
}

.season-arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 40rpx;
  height: 72rpx;
  background-color: rgba(0, 0, 0, 0.4);
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background-color 100ms ease-out, transform 100ms ease-out, opacity 100ms ease-out;
}

.season-arrow-left {
  left: 10rpx;
}

.season-arrow-right {
  right: 10rpx;
}

.season-arrow-hover {
  background-color: rgba(0, 0, 0, 0.55);
  transform: translateY(-50%) scale(0.96);
}

.season-arrow-hover .arrow-text {
  opacity: 0.85;
}

.arrow-text {
  display: block;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 300;
  line-height: 1;
  margin: -2rpx 0 0 2rpx;
}

/* 加载动画样式 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100vw;
  height: calc(100vh - 110rpx);
  position: fixed;
  top: 0;
  left: 0;
  background: linear-gradient(180deg, #F1F8E9 0%, #DCEDC8 100%);
  z-index: 10000;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid rgba(27, 61, 43, 0.12);
  border-top: 6rpx solid #1B3D2B;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.loading-text {
  margin-top: 30rpx;
  font-size: 28rpx;
  color: #1B3D2B;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

@import 'home-wxa-auto-dark.wxss'
