<view class="container">
  <view class="header">
    <text class="title">项目总览</text>
  </view>
  
  <view class="content">
    <view class="card map-card">
      <view class="map-card-header">
        <text class="card-title">观鸟地图</text>
        <view class="map-expand-btn" hover-class="map-expand-btn-hover" hover-start-time="0" hover-stay-time="120" bindtap="onMapExpandTap">
          <text class="map-expand-icon">⛶</text>
        </view>
      </view>
      <view class="map-container">
        <map
          id="beijingMap"
          longitude="{{mapData.longitude}}"
          latitude="{{mapData.latitude}}"
          scale="{{mapData.scale}}"
          min-scale="6"
          markers="{{mapData.markers}}"
          show-location
          style="width: 100%; height: 100%;"
        ></map>
      </view>
    </view>
    
    <view class="card daily-bird-card" bindtap="onDailyBirdTap">
      <text class="card-title">为你推荐</text>
      <view class="daily-bird-content">
        <view class="daily-bird-image">
          <view class="image-placeholder"></view>
        </view>
        <view class="daily-bird-info">
          <text class="bird-name">名称</text>
          <text class="bird-latin">xueming</text>
          <text class="bird-intro">鸟类介绍…</text>
        </view>
      </view>
    </view>
    
    <view class="card season-bird-card">
      <view class="season-bird-header">
        <text class="card-title season-bird-title">当季常见鸟类</text>
        <text class="season-bird-link-top">鸟类图鉴 ›</text>
      </view>
      <view class="season-bird-image-wrapper">
        <image
          class="season-bird-image"
          src="{{seasonBirds[currentIndex].image}}"
          mode="aspectFill"
        ></image>
        <view class="season-bird-gradient"></view>
        <view class="season-bird-overlay-bottom">
          <text class="season-bird-name">{{seasonBirds[currentIndex].name}}</text>
          <text class="season-bird-detail-link">查看详情 ›</text>
        </view>
        <view class="season-arrow season-arrow-left" hover-class="season-arrow-hover" hover-stay-time="120" hover-start-time="0" bindtap="onPrevSeasonBird">
          <text class="arrow-text">‹</text>
        </view>
        <view class="season-arrow season-arrow-right" hover-class="season-arrow-hover" hover-stay-time="120" hover-start-time="0" bindtap="onNextSeasonBird">
          <text class="arrow-text">›</text>
        </view>
      </view>
    </view>
    
    <view class="card">
      <text class="card-title">志愿者招募</text>
      <text class="card-desc">内容待填充</text>
    </view>
  </view>
</view>

<view wx:if="{{isLoading}}" class="loading-container">
  <view class="loading-spinner"></view>
  <text class="loading-text">加载中...</text>
</view>
