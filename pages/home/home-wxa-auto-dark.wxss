@media (prefers-color-scheme: dark) {
    .container {
        background: linear-gradient(180deg, #1B3D2B 0%, #0F2319 100%);
    }

    .title {
        color: #C8E8CA;
    }

    .card {
        background-color: rgb(17, 17, 17);
        box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.45);
    }

    .card-title {
        color: rgb(209, 209, 209);
    }

    .card-desc {
        color: rgb(99, 99, 99);
    }

    .map-card .card-title {
        color: rgb(209, 209, 209);
    }

    .map-expand-btn-hover {
        background-color: rgba(255, 255, 255, 0.08);
    }

    .daily-bird-inner {
        background-color: #142E22;
    }

    /* 通用 .bd-* 鸟类卡片暗色样式已抽到 app-wxa-auto-dark.wxss */

    .season-bird-card .season-bird-title {
        color: rgb(209, 209, 209);
    }

    .season-bird-link-top {
        color: rgb(209, 209, 209);
    }

    .season-bird-image {
        background-color: rgb(64, 64, 64);
    }

    .loading-container {
        background: linear-gradient(180deg, #1B3D2B 0%, #0F2319 100%);
    }

    .loading-text {
        color: #C8E8CA;
    }

    .loading-spinner {
        border: 6rpx solid rgb(64, 64, 64);
        border-top: 6rpx solid #C8E8CA;
    }

    @keyframes spin {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }
}
