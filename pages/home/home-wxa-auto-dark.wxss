@media (prefers-color-scheme: dark) {
    .container {
        background-color: rgb(42, 42, 42);
    }

    .title {
        color: rgb(127, 178, 133);
    }

    .card {
        background-color: rgb(17, 17, 17);
    }

    .card-title {
        color: rgb(209, 209, 209);
    }

    .card-desc {
        color: rgb(99, 99, 99);
    }

    .map-card .card-title {
        color: rgb(209, 209, 209);
    }

    .map-expand-btn-hover {
        background-color: rgba(255, 255, 255, 0.08);
    }

    .daily-bird-inner {
        background-color: rgba(127, 178, 133, 0.04);
    }

    .daily-bird-card .bd-name {
        color: rgb(127, 178, 133);
    }

    .daily-bird-card .bd-sci {
        color: rgb(150, 150, 150);
    }

    .daily-bird-card .bd-feature {
        color: rgb(120, 120, 120);
    }

    .daily-bird-card .bd-tag {
        background-color: rgba(127, 178, 133, 0.08);
    }

    .daily-bird-card .bd-tag-text {
        color: rgb(127, 178, 133);
    }

    .season-bird-card .season-bird-title {
        color: rgb(209, 209, 209);
    }

    .season-bird-link-top {
        color: rgb(209, 209, 209);
    }

    .season-bird-image {
        background-color: rgb(64, 64, 64);
    }

    .loading-container {
        background-color: rgb(31, 31, 31);
    }

    .loading-text {
        color: rgb(200, 200, 200);
    }

    .loading-spinner {
        border: 6rpx solid rgb(64, 64, 64);
        border-top: 6rpx solid rgb(127, 178, 133);
    }

    .loading-text {
        color: rgb(127, 178, 133);
    }

    @keyframes spin {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }
}
