@media (prefers-color-scheme: dark) {
    .container {
        background: linear-gradient(180deg, #1B3D2B 0%, #0F2319 100%);
    }

    .title {
        color: #C8E8CA;
    }

    .section {
        background-color: rgb(17, 17, 17);
        box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.45);
    }

    .section-title {
        color: rgb(209, 209, 209);
    }

    .section-desc {
        color: rgb(170, 170, 170);
    }

    .loading-container {
        background: linear-gradient(180deg, #1B3D2B 0%, #0F2319 100%);
    }

    .loading-spinner {
        border: 6rpx solid rgb(64, 64, 64);
        border-top: 6rpx solid #C8E8CA;
    }

    .loading-text {
        color: #C8E8CA;
    }

    @keyframes spin {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }
}