@media (prefers-color-scheme: dark) {
    .container {
        background-color: rgb(42, 42, 42);
    }

    .title {
        color: rgb(127, 178, 133);
    }

    .section {
        background-color: rgb(17, 17, 17);
    }

    .section-title {
        color: rgb(209, 209, 209);
    }

    .section-desc {
        color: rgb(170, 170, 170);
    }

    .loading-container {
        background-color: rgb(42, 42, 42);
    }

    .loading-spinner {
        border: 6rpx solid rgb(64, 64, 64);
        border-top: 6rpx solid rgb(127, 178, 133);
    }

    .loading-text {
        color: rgb(127, 178, 133);
    }

    @keyframes spin {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }
}