<view wx:if="{{isLoading}}" class="loading-container">
  <view class="loading-spinner"></view>
  <text class="loading-text">加载中...</text>
</view>

<view wx:else class="container">
  <view class="header">
    <text class="title">生态区域</text>
  </view>

  <view class="content">
    <!-- 生态区卡片 1（示例占位） -->
    <view class="card">
      <view class="ec-cover">
        <image
          class="ec-cover-image"
          src="/assets/ecosystems/yuyuantan.jpg"
          mode="aspectFill"
        ></image>
        <view class="ec-cover-gradient"></view>
        <view class="ec-cover-title-wrapper">
          <text class="ec-cover-title">生态区1</text>
        </view>
        <view class="ec-cover-arrow" hover-class="ec-cover-arrow-hover" hover-stay-time="120" hover-start-time="0" bindtap="onEcosystemArrowTap">
          <text class="ec-cover-arrow-text">›</text>
        </view>
      </view>

      <view class="ec-tags">
        <view class="ec-tag"><text class="ec-tag-text">标签1</text></view>
        <view class="ec-tag"><text class="ec-tag-text">标签2</text></view>
      </view>

      <view class="ec-location">
        <text class="ec-location-icon">📍</text>
        <text class="ec-location-text">北京市 XX区</text>
      </view>
    </view>
  </view>
</view>