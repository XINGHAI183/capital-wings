<view wx:if="{{isLoading}}" class="loading-container">
  <view class="loading-spinner"></view>
  <text class="loading-text">加载中...</text>
</view>

<view wx:else class="container">
  <view class="header">
    <text class="title">鸟类图鉴</text>
  </view>

  <view class="content">
    <view class="filter-bar">
      <view
        class="filter-item {{filterMode === 'pinyin' ? 'filter-item-active' : ''}}"
        hover-class="filter-item-hover"
        hover-stay-time="120"
        hover-start-time="0"
        bindtap="onFilterTap"
        data-mode="pinyin"
      >
        <text class="filter-item-text">按拼音</text>
      </view>
      <view
        class="filter-item {{filterMode === 'ecosystem' ? 'filter-item-active' : ''}}"
        hover-class="filter-item-hover"
        hover-stay-time="120"
        hover-start-time="0"
        bindtap="onFilterTap"
        data-mode="ecosystem"
      >
        <text class="filter-item-text">按生态区</text>
      </view>
    </view>
    <!-- 按拼音：鸟类卡片列表 -->
    <block wx:if="{{filterMode === 'pinyin'}}">
      <view class="card">
        <view class="bd-card-row">
          <view class="bd-image">
            <image
              class="bd-image-img"
              src="/assets/birds/guide/baitoubei.jpg"
              mode="aspectFill"
            />
          </view>
          <view class="bd-info">
            <view class="bd-info-top">
              <text class="bd-name">白头鹎</text>
              <text class="bd-sci">Pycnonotus sinensis</text>
            </view>
            <view class="bd-features">
              <text class="bd-feature">XXXXXXXXXXXXXXXXXXXXXXXXXXXX</text>
              <text class="bd-feature">XXXXXXXXXXXXXXXXXXXXXXXXXXXX</text>
            </view>
            <view class="bd-tags">
              <view class="bd-tag"><text class="bd-tag-text">标签1</text></view>
              <view class="bd-tag"><text class="bd-tag-text">标签2</text></view>
            </view>
          </view>
        </view>
      </view>
      <view class="card">
        <view class="bd-card-row">
          <view class="bd-image">
            <image
              class="bd-image-img"
              src="/assets/birds/guide/damajian.jpg"
              mode="aspectFill"
            />
          </view>
          <view class="bd-info">
            <view class="bd-info-top">
              <text class="bd-name">大麻鳽</text>
              <text class="bd-sci">Botaurus stellaris</text>
            </view>
            <view class="bd-features">
              <text class="bd-feature">XXXXXXXXXXXXXXXXXXXXXXXXXXXX</text>
              <text class="bd-feature">XXXXXXXXXXXXXXXXXXXXXXXXXXXX</text>
            </view>
            <view class="bd-tags">
              <view class="bd-tag"><text class="bd-tag-text">标签1</text></view>
              <view class="bd-tag"><text class="bd-tag-text">标签2</text></view>
            </view>
          </view>
        </view>
      </view>
      <view class="card">
        <view class="bd-card-row">
          <view class="bd-image">
            <image
              class="bd-image-img"
              src="/assets/birds/guide/jiaoliao.jpg"
              mode="aspectFill"
            />
          </view>
          <view class="bd-info">
            <view class="bd-info-top">
              <text class="bd-name">鹪鹩</text>
              <text class="bd-sci">Troglodytes troglodytes</text>
            </view>
            <view class="bd-features">
              <text class="bd-feature">XXXXXXXXXXXXXXXXXXXXXXXXXXXX</text>
              <text class="bd-feature">XXXXXXXXXXXXXXXXXXXXXXXXXXXX</text>
            </view>
            <view class="bd-tags">
              <view class="bd-tag"><text class="bd-tag-text">标签1</text></view>
              <view class="bd-tag"><text class="bd-tag-text">标签2</text></view>
            </view>
          </view>
        </view>
      </view>
      <view class="card">
        <view class="bd-card-row">
          <view class="bd-image">
            <image
              class="bd-image-img"
              src="/assets/birds/guide/sandaomeicaowu.jpg"
              mode="aspectFill"
            />
          </view>
          <view class="bd-info">
            <view class="bd-info-top">
              <text class="bd-name">三道眉草鹀</text>
              <text class="bd-sci">Emberiza cioides</text>
            </view>
            <view class="bd-features">
              <text class="bd-feature">XXXXXXXXXXXXXXXXXXXXXXXXXXXX</text>
              <text class="bd-feature">XXXXXXXXXXXXXXXXXXXXXXXXXXXX</text>
            </view>
            <view class="bd-tags">
              <view class="bd-tag"><text class="bd-tag-text">标签1</text></view>
              <view class="bd-tag"><text class="bd-tag-text">标签2</text></view>
            </view>
          </view>
        </view>
      </view>
    </block>

    <!-- 按生态区：生态区卡片列表 -->
    <block wx:if="{{filterMode === 'ecosystem'}}">
      <view class="card">
        <view class="ec-cover">
          <image
            class="ec-cover-image"
            src="/assets/ecosystems/yuyuantan.jpg"
            mode="aspectFill"
          />
          <view class="ec-cover-gradient" />
          <view class="ec-cover-title-wrapper">
            <text class="ec-cover-title">玉渊潭</text>
          </view>
          <view
            class="ec-cover-arrow"
            hover-class="ec-cover-arrow-hover"
            hover-stay-time="120"
            hover-start-time="0"
            bindtap="onEcosystemArrowTap"
          >
            <text class="ec-cover-arrow-text">›</text>
          </view>
        </view>

        <view class="ec-tags">
          <view class="ec-tag">
            <text class="ec-tag-text">戴胜</text>
          </view>
          <view class="ec-tag">
            <text class="ec-tag-text">大斑啄木鸟</text>
          </view>
          <view class="ec-tag">
            <text class="ec-tag-text">灰喜鹊</text>
          </view>
        </view>

        <view class="ec-location">
          <text class="ec-location-icon">📍</text>
          <text class="ec-location-text">北京市 XX区</text>
        </view>
      </view>
      <view class="card">
        <view class="ec-cover">
          <image
            class="ec-cover-image"
            src="/assets/ecosystems/nanyuan.jpg"
            mode="aspectFill"
          />
          <view class="ec-cover-gradient" />
          <view class="ec-cover-title-wrapper">
            <text class="ec-cover-title">南苑</text>
          </view>
          <view
            class="ec-cover-arrow"
            hover-class="ec-cover-arrow-hover"
            hover-stay-time="120"
            hover-start-time="0"
            bindtap="onEcosystemArrowTap"
          >
            <text class="ec-cover-arrow-text">›</text>
          </view>
        </view>

        <view class="ec-tags">
          <view class="ec-tag">
            <text class="ec-tag-text">雀鹰</text>
          </view>
          <view class="ec-tag">
            <text class="ec-tag-text">红隼</text>
          </view>
          <view class="ec-tag">
            <text class="ec-tag-text">大鵟</text>
          </view>
        </view>

        <view class="ec-location">
          <text class="ec-location-icon">📍</text>
          <text class="ec-location-text">北京市 XX区</text>
        </view>
      </view>
      <view class="card">
        <view class="ec-cover">
          <image
            class="ec-cover-image"
            src="/assets/ecosystems/aosen.jpg"
            mode="aspectFill"
          />
          <view class="ec-cover-gradient" />
          <view class="ec-cover-title-wrapper">
            <text class="ec-cover-title">奥森</text>
          </view>
          <view
            class="ec-cover-arrow"
            hover-class="ec-cover-arrow-hover"
            hover-stay-time="120"
            hover-start-time="0"
            bindtap="onEcosystemArrowTap"
          >
            <text class="ec-cover-arrow-text">›</text>
          </view>
        </view>

        <view class="ec-tags">
          <view class="ec-tag">
            <text class="ec-tag-text">星头啄木鸟</text>
          </view>
          <view class="ec-tag">
            <text class="ec-tag-text">牛头伯劳</text>
          </view>
          <view class="ec-tag">
            <text class="ec-tag-text">红嘴蓝鹊</text>
          </view>
        </view>

        <view class="ec-location">
          <text class="ec-location-icon">📍</text>
          <text class="ec-location-text">北京市 XX区</text>
        </view>
      </view>
    </block>
  </view>
</view>
