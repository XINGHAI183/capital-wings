<view wx:if="{{isLoading}}" class="loading-container">
  <view class="loading-spinner"></view>
  <text class="loading-text">加载中...</text>
</view>

<view wx:else class="container">
  <view class="header">
    <text class="title">鸟类图鉴</text>
  </view>

  <view class="content">
    <view class="card">
      <view class="bd-card-row">
        <view class="bd-image"></view>
        <view class="bd-info">
          <view class="bd-info-top">
            <text class="bd-name">鸟类1</text>
            <text class="bd-sci">xueming</text>
          </view>
          <view class="bd-features">
            <text class="bd-feature">XXXXXXXXXXXXXXXXXXXXXXXXXXXX</text>
            <text class="bd-feature">XXXXXXXXXXXXXXXXXXXXXXXXXXXX</text>
          </view>
          <view class="bd-tags">
            <view class="bd-tag"><text class="bd-tag-text">标签1</text></view>
            <view class="bd-tag"><text class="bd-tag-text">标签2</text></view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
