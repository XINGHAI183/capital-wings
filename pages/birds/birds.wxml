<view wx:if="{{isLoading}}" class="loading-container">
  <view class="loading-spinner"></view>
  <text class="loading-text">加载中...</text>
</view>

<view wx:else class="container">
  <view class="header">
    <text class="title">鸟类图鉴</text>
  </view>

  <view class="content">
    <view class="card">
      <text class="card-title">鸟种分类</text>
      <text class="card-desc">内容待填充</text>
    </view>

    <view class="card">
      <text class="card-title">常见鸟种</text>
      <text class="card-desc">内容待填充</text>
    </view>

    <view class="card">
      <text class="card-title">稀有鸟种</text>
      <text class="card-desc">内容待填充</text>
    </view>
  </view>
</view>
