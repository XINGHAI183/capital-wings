<view wx:if="{{isLoading}}" class="loading-container">
  <view class="loading-spinner"></view>
  <text class="loading-text">加载中...</text>
</view>

<view wx:else class="container">
  <view class="header">
    <text class="title">鸟类图鉴</text>
  </view>

  <view class="content">
    <view class="filter-bar">
      <view
        class="filter-item {{filterMode === 'pinyin' ? 'filter-item-active' : ''}}"
        hover-class="filter-item-hover"
        hover-stay-time="120"
        hover-start-time="0"
        bindtap="onFilterTap"
        data-mode="pinyin"
      >
        <text class="filter-item-text">按拼音</text>
      </view>
      <view
        class="filter-item {{filterMode === 'ecosystem' ? 'filter-item-active' : ''}}"
        hover-class="filter-item-hover"
        hover-stay-time="120"
        hover-start-time="0"
        bindtap="onFilterTap"
        data-mode="ecosystem"
      >
        <text class="filter-item-text">按生态区</text>
      </view>
    </view>
    <!-- 按拼音：鸟类卡片列表 -->
    <block wx:if="{{filterMode === 'pinyin'}}">
      <view
        class="card"
        wx:for="{{birdList}}"
        wx:key="index"
        data-index="{{index}}"
        bindtap="onBirdCardTap"
      >
        <view class="bd-card-row">
          <view class="bd-image">
            <image
              class="bd-image-img"
              src="{{item.image}}"
              mode="aspectFill"
            />
          </view>
          <view class="bd-info">
            <view class="bd-info-top">
              <text class="bd-name">{{item.name}}</text>
              <text class="bd-sci">{{item.sciName}}</text>
            </view>
            <view class="bd-features">
              <text class="bd-feature" wx:for="{{item.features}}" wx:for-item="feature" wx:key="*this">{{feature}}</text>
            </view>
            <view class="bd-tags">
              <view class="bd-tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this"><text class="bd-tag-text">{{tag}}</text></view>
            </view>
          </view>
        </view>
      </view>
    </block>

    <!-- 按生态区：生态区卡片列表 -->
    <block wx:if="{{filterMode === 'ecosystem'}}">
      <view class="card">
        <view class="ec-cover">
          <image
            class="ec-cover-image"
            src="/assets/ecosystems/yuyuantan.jpg"
            mode="aspectFill"
          />
          <view class="ec-cover-gradient" />
          <view class="ec-cover-title-wrapper">
            <text class="ec-cover-title">玉渊潭</text>
          </view>
          <view
            class="ec-cover-arrow"
            hover-class="ec-cover-arrow-hover"
            hover-stay-time="120"
            hover-start-time="0"
            bindtap="onEcosystemArrowTap"
          >
            <text class="ec-cover-arrow-text">›</text>
          </view>
        </view>

        <view class="ec-tags">
          <view class="ec-tag">
            <text class="ec-tag-text">戴胜</text>
          </view>
          <view class="ec-tag">
            <text class="ec-tag-text">大斑啄木鸟</text>
          </view>
          <view class="ec-tag">
            <text class="ec-tag-text">灰喜鹊</text>
          </view>
        </view>

        <view class="ec-location">
          <text class="ec-location-icon">📍</text>
          <text class="ec-location-text">北京市 XX区</text>
        </view>
      </view>
      <view class="card">
        <view class="ec-cover">
          <image
            class="ec-cover-image"
            src="/assets/ecosystems/nanyuan.jpg"
            mode="aspectFill"
          />
          <view class="ec-cover-gradient" />
          <view class="ec-cover-title-wrapper">
            <text class="ec-cover-title">南苑</text>
          </view>
          <view
            class="ec-cover-arrow"
            hover-class="ec-cover-arrow-hover"
            hover-stay-time="120"
            hover-start-time="0"
            bindtap="onEcosystemArrowTap"
          >
            <text class="ec-cover-arrow-text">›</text>
          </view>
        </view>

        <view class="ec-tags">
          <view class="ec-tag">
            <text class="ec-tag-text">雀鹰</text>
          </view>
          <view class="ec-tag">
            <text class="ec-tag-text">红隼</text>
          </view>
          <view class="ec-tag">
            <text class="ec-tag-text">大鵟</text>
          </view>
        </view>

        <view class="ec-location">
          <text class="ec-location-icon">📍</text>
          <text class="ec-location-text">北京市 XX区</text>
        </view>
      </view>
      <view class="card">
        <view class="ec-cover">
          <image
            class="ec-cover-image"
            src="/assets/ecosystems/aosen.jpg"
            mode="aspectFill"
          />
          <view class="ec-cover-gradient" />
          <view class="ec-cover-title-wrapper">
            <text class="ec-cover-title">奥森</text>
          </view>
          <view
            class="ec-cover-arrow"
            hover-class="ec-cover-arrow-hover"
            hover-stay-time="120"
            hover-start-time="0"
            bindtap="onEcosystemArrowTap"
          >
            <text class="ec-cover-arrow-text">›</text>
          </view>
        </view>

        <view class="ec-tags">
          <view class="ec-tag">
            <text class="ec-tag-text">星头啄木鸟</text>
          </view>
          <view class="ec-tag">
            <text class="ec-tag-text">牛头伯劳</text>
          </view>
          <view class="ec-tag">
            <text class="ec-tag-text">红嘴蓝鹊</text>
          </view>
        </view>

        <view class="ec-location">
          <text class="ec-location-icon">📍</text>
          <text class="ec-location-text">北京市 XX区</text>
        </view>
      </view>
    </block>
  </view>

  <!-- 图鉴详情弹窗 -->
  <view class="detail-modal {{closing ? 'detail-modal-closing' : ''}}" wx:if="{{showDetail}}" catchtouchmove="preventTouchMove">
    <view class="detail-modal-mask" />
    <view class="detail-modal-content" catchtap="onModalContentTap">
      <view class="detail-modal-header">
        <text class="detail-modal-title">图鉴详情</text>
        <view class="detail-modal-close" catchtap="onCloseDetail">
          <text class="detail-modal-close-text">×</text>
        </view>
      </view>
      <view class="detail-modal-body">
        <view class="detail-bird-card" wx:if="{{birdList[selectedBirdIndex]}}">
          <view class="detail-bird-inner">
            <view class="bd-card-row">
              <view class="bd-image">
                <image
                  class="bd-image-img"
                  src="{{birdList[selectedBirdIndex].image}}"
                  mode="aspectFill"
                />
              </view>
              <view class="bd-info">
                <view class="bd-info-top">
                  <text class="bd-name">{{birdList[selectedBirdIndex].name}}</text>
                  <text class="bd-sci">{{birdList[selectedBirdIndex].sciName}}</text>
                </view>
                <view class="bd-features">
                  <text class="bd-feature" wx:for="{{birdList[selectedBirdIndex].features}}" wx:for-item="feature" wx:key="*this">{{feature}}</text>
                </view>
                <view class="bd-tags">
                  <view class="bd-tag" wx:for="{{birdList[selectedBirdIndex].tags}}" wx:for-item="tag" wx:key="*this"><text class="bd-tag-text">{{tag}}</text></view>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
    <view class="detail-modal-top-closer" bindtap="onCloseDetail" />
  </view>
</view>
