.container {
  padding: 20rpx 20rpx calc(130rpx + env(safe-area-inset-bottom));
  min-height: 100vh;
  box-sizing: border-box;
  background: linear-gradient(180deg, #F1F8E9 0%, #DCEDC8 100%);
}

.header {
  padding: 40rpx 20rpx;
  text-align: left;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #1B3D2B;
}

/* 筛选切换条 */
.filter-bar {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  padding: 0 20rpx;
  margin-bottom: 20rpx;
}

.filter-item {
  flex: 1;
  height: 72rpx;
  border-radius: 16rpx;
  background-color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  transition: background-color 120ms ease-out, transform 120ms ease-out;
}

.filter-item-hover {
  transform: scale(0.98);
  background-color: rgba(27, 61, 43, 0.06);
}

.filter-item-active {
  background-color: rgba(27, 61, 43, 0.12);
}

.filter-item-text {
  font-size: 28rpx;
  color: #1B3D2B;
  font-weight: 500;
}

.content {
  padding: 20rpx 0;
}

.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.card-desc {
  display: block;
  font-size: 28rpx;
  color: #999999;
}

/* 鸟类卡片 —— 行布局：左侧窄高图片，右侧文本 */
/* 通用 .bd-* 样式已抽到 app.wxss，此处仅保留页面级覆盖 */

.card > .bd-card-row {
  margin: -10rpx;
}

.detail-bird-inner .bd-card-row {
  margin: 0;
}

/* 生态区卡片 —— 封面图区域 */
.ec-cover {
  position: relative;
  margin: -10rpx -10rpx 24rpx -10rpx;
  height: 360rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background-color: #E0E0E0;
}

.ec-cover-image {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  width: 100%;
  height: 100%;
  display: block;
}

.ec-cover-gradient {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 50%;
  background: linear-gradient(to bottom, transparent 0%, rgba(0, 0, 0, 0.65) 100%);
  pointer-events: none;
}

.ec-cover-title-wrapper {
  position: absolute;
  left: 30rpx;
  right: 30rpx;
  bottom: 24rpx;
  z-index: 2;
}

.ec-cover-title {
  font-family: "宋体", SimSun, serif;
  font-size: 50rpx;
  font-weight: 600;
  line-height: 1.2;
  color: #ffffff;
}

.ec-cover-arrow {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 50rpx;
  height: 50rpx;
  background-color: rgba(0, 0, 0, 0.4);
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 3;
  transition: background-color 100ms ease-out, transform 100ms ease-out, opacity 100ms ease-out;
}

.ec-cover-arrow-hover {
  background-color: rgba(0, 0, 0, 0.55);
  transform: scale(0.96);
}

.ec-cover-arrow-hover .ec-cover-arrow-text {
  opacity: 0.85;
}

.ec-cover-arrow-text {
  display: block;
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 100;
  line-height: 1;
  margin: -8rpx 0 0 2rpx;
}

/* 生态区标签行 */
.ec-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.ec-tag {
  height: 50rpx;
  padding: 0 26rpx;
  border-radius: 25rpx;
  background-color: rgba(27, 61, 43, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
}

.ec-tag-text {
  font-size: 28rpx;
  color: #1B3D2B;
}

/* 行政区域 */
.ec-location {
  display: flex;
  align-items: center;
}

.ec-location-icon {
  font-size: 28rpx;
  color: #1B3D2B;
  margin-right: 8rpx;
  line-height: 1;
}

.ec-location-text {
  font-size: 26rpx;
  color: #1B3D2B;
}

/* 加载动画样式 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100vw;
  height: calc(100vh - 110rpx);
  position: fixed;
  top: 0;
  left: 0;
  background: linear-gradient(180deg, #F1F8E9 0%, #DCEDC8 100%);
  z-index: 10000;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid rgba(27, 61, 43, 0.12);
  border-top: 6rpx solid #1B3D2B;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.loading-text {
  margin-top: 30rpx;
  font-size: 28rpx;
  color: #1B3D2B;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 图鉴详情弹窗 */
.detail-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20000;
}

.detail-modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  opacity: 1;
  transition: opacity 350ms cubic-bezier(0.32, 0.72, 0, 1);
}

.detail-modal-closing .detail-modal-mask {
  opacity: 0;
}

.detail-modal-top-closer {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 130rpx;
}

.detail-modal-content {
  position: absolute;
  top: 130rpx;
  left: 20rpx;
  right: 20rpx;
  bottom: 0;
  background-color: #ffffff;
  border-radius: 16rpx 16rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  animation: detailSlideUp 350ms cubic-bezier(0.32, 0.72, 0, 1);
}

.detail-modal-closing .detail-modal-content {
  animation: detailSlideDown 350ms cubic-bezier(0.32, 0.72, 0, 1) forwards;
}

@keyframes detailSlideUp {
  0% { transform: translateY(100%); }
  100% { transform: translateY(0); }
}

@keyframes detailSlideDown {
  0% { transform: translateY(0); }
  100% { transform: translateY(100%); }
}

.detail-modal-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.08);
}

.detail-modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1B3D2B;
}

.detail-modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  flex-shrink: 0;
  background-color: transparent;
  transition: background-color 120ms ease-out;
}

.detail-modal-close-hover {
  background-color: rgba(0, 0, 0, 0.08);
}

.detail-modal-close-text {
  font-size: 40rpx;
  line-height: 1;
  color: #999999;
}

.detail-modal-body {
  flex: 1;
  padding: 30rpx;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.detail-inner-card {
  background-color: #F4F9ED;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.detail-inner-card-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.detail-gallery {
  width: 100%;
  border-radius: 12rpx;
  overflow: hidden;
}

.detail-gallery-cover {
  width: 100%;
  height: 400rpx;
  display: block;
  background-color: #E0E0E0;
}

.detail-intro-features {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.detail-intro-feature {
  font-size: 28rpx;
  line-height: 1.6;
  color: #666666;
}

@import 'birds-wxa-auto-dark.wxss'
