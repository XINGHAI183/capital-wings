.container {
  padding: 20rpx 20rpx calc(130rpx + env(safe-area-inset-bottom));
  min-height: 100vh;
  box-sizing: border-box;
  background: linear-gradient(180deg, #F1F8E9 0%, #DCEDC8 100%);
}

.header {
  padding: 40rpx 20rpx;
  text-align: left;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #1B3D2B;
}

/* 筛选切换条 */
.filter-bar {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  padding: 0 20rpx;
  margin-bottom: 20rpx;
}

.filter-item {
  flex: 1;
  height: 72rpx;
  border-radius: 16rpx;
  background-color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  transition: background-color 120ms ease-out, transform 120ms ease-out;
}

.filter-item-hover {
  transform: scale(0.98);
  background-color: rgba(27, 61, 43, 0.06);
}

.filter-item-active {
  background-color: rgba(27, 61, 43, 0.12);
}

.filter-item-text {
  font-size: 28rpx;
  color: #1B3D2B;
  font-weight: 500;
}

.content {
  padding: 20rpx 0;
}

.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.card-desc {
  display: block;
  font-size: 28rpx;
  color: #999999;
}

/* 鸟类卡片 —— 行布局：左侧窄高图片，右侧文本 */
.bd-card-row {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  margin: -10rpx;
}

.bd-image {
  width: 180rpx;
  height: 250rpx;
  border-radius: 12rpx;
  background-color: #E0E0E0;
  flex-shrink: 0;
  overflow: hidden;
}

.bd-image-img {
  width: 100%;
  height: 100%;
  display: block;
}

.bd-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  margin-left: 20rpx;
}

.bd-info-top {
  display: flex;
  flex-direction: column;
}

.bd-name {
  font-family: "宋体", SimSun, serif;
  font-size: 45rpx;
  font-weight: 600;
  line-height: 1.2;
  color: #1B3D2B;
}

.bd-sci {
  font-style: italic;
  font-size: 25rpx;
  line-height: 1.2;
  color: #999999;
  margin-top: 2rpx;
}

.bd-features {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.bd-feature {
  font-size: 24rpx;
  line-height: 1.4;
  color: #888888;
}

.bd-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.bd-tag {
  height: 50rpx;
  padding: 0 26rpx;
  border-radius: 25rpx;
  background-color: rgba(27, 61, 43, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
}

.bd-tag-text {
  font-size: 28rpx;
  color: #1B3D2B;
}

/* 生态区卡片 —— 封面图区域 */
.ec-cover {
  position: relative;
  margin: -10rpx -10rpx 24rpx -10rpx;
  height: 360rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background-color: #E0E0E0;
}

.ec-cover-image {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  width: 100%;
  height: 100%;
  display: block;
}

.ec-cover-gradient {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 50%;
  background: linear-gradient(to bottom, transparent 0%, rgba(0, 0, 0, 0.65) 100%);
  pointer-events: none;
}

.ec-cover-title-wrapper {
  position: absolute;
  left: 30rpx;
  right: 30rpx;
  bottom: 24rpx;
  z-index: 2;
}

.ec-cover-title {
  font-family: "宋体", SimSun, serif;
  font-size: 50rpx;
  font-weight: 600;
  line-height: 1.2;
  color: #ffffff;
}

.ec-cover-arrow {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 50rpx;
  height: 50rpx;
  background-color: rgba(0, 0, 0, 0.4);
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 3;
  transition: background-color 100ms ease-out, transform 100ms ease-out, opacity 100ms ease-out;
}

.ec-cover-arrow-hover {
  background-color: rgba(0, 0, 0, 0.55);
  transform: scale(0.96);
}

.ec-cover-arrow-hover .ec-cover-arrow-text {
  opacity: 0.85;
}

.ec-cover-arrow-text {
  display: block;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 300;
  line-height: 1;
  margin: -2rpx 0 0 4rpx;
}

/* 生态区标签行 */
.ec-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.ec-tag {
  height: 50rpx;
  padding: 0 26rpx;
  border-radius: 25rpx;
  background-color: rgba(27, 61, 43, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
}

.ec-tag-text {
  font-size: 28rpx;
  color: #1B3D2B;
}

/* 行政区域 */
.ec-location {
  display: flex;
  align-items: center;
}

.ec-location-icon {
  font-size: 28rpx;
  color: #1B3D2B;
  margin-right: 8rpx;
  line-height: 1;
}

.ec-location-text {
  font-size: 26rpx;
  color: #1B3D2B;
}

/* 加载动画样式 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100vw;
  height: calc(100vh - 110rpx);
  position: fixed;
  top: 0;
  left: 0;
  background: linear-gradient(180deg, #F1F8E9 0%, #DCEDC8 100%);
  z-index: 10000;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid rgba(27, 61, 43, 0.12);
  border-top: 6rpx solid #1B3D2B;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.loading-text {
  margin-top: 30rpx;
  font-size: 28rpx;
  color: #1B3D2B;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

@import 'birds-wxa-auto-dark.wxss'
