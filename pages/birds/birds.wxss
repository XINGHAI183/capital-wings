.container {
  padding: 20rpx 20rpx calc(130rpx + env(safe-area-inset-bottom));
  min-height: 100vh;
  box-sizing: border-box;
  background-color: #E0E0E0;
}

.header {
  padding: 40rpx 20rpx;
  text-align: left;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #4A4E63;
}

.content {
  padding: 20rpx 0;
}

.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.card-desc {
  display: block;
  font-size: 28rpx;
  color: #999999;
}

/* 鸟类卡片 —— 行布局：左侧窄高图片，右侧文本 */
.bd-card-row {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  margin: -10rpx;
}

.bd-image {
  width: 180rpx;
  height: 250rpx;
  border-radius: 12rpx;
  background-color: #E0E0E0;
  flex-shrink: 0;
}

.bd-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  margin-left: 20rpx;
}

.bd-info-top {
  display: flex;
  flex-direction: column;
}

.bd-name {
  font-family: "宋体", SimSun, serif;
  font-size: 50rpx;
  font-weight: 600;
  line-height: 1.2;
  color: #4A4E63;
}

.bd-sci {
  font-style: italic;
  font-size: 28rpx;
  line-height: 1.2;
  color: #999999;
  margin-top: 2rpx;
}

.bd-features {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.bd-feature {
  font-size: 24rpx;
  line-height: 1.4;
  color: #888888;
}

.bd-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.bd-tag {
  height: 50rpx;
  padding: 0 26rpx;
  border-radius: 25rpx;
  background-color: rgba(74, 78, 99, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
}

.bd-tag-text {
  font-size: 28rpx;
  color: #4A4E63;
}

/* 加载动画样式 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100vw;
  height: calc(100vh - 110rpx);
  position: fixed;
  top: 0;
  left: 0;
  background-color: #EBEBEB;
  z-index: 10000;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #E0E0E0;
  border-top: 6rpx solid #4A4E63;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.loading-text {
  margin-top: 30rpx;
  font-size: 28rpx;
  color: #4A4E63;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

@import 'birds-wxa-auto-dark.wxss'
