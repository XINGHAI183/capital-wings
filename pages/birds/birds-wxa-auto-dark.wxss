@media (prefers-color-scheme: dark) {
    .container {
        background-color: rgb(42, 42, 42);
    }

    .title {
        color: rgb(127, 178, 133);
    }

    .card {
        background-color: rgb(17, 17, 17);
    }

    .card-title {
        color: rgb(209, 209, 209);
    }

    .card-desc {
        color: rgb(99, 99, 99);
    }

    .bd-name {
        color: rgb(127, 178, 133);
    }

    .bd-tag {
        background-color: rgba(127, 178, 133, 0.08);
    }

    .bd-tag-text {
        color: rgb(127, 178, 133);
    }

    .filter-item {
        background-color: rgb(17, 17, 17);
        box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.4);
    }

    .filter-item-hover {
        background-color: rgba(127, 178, 133, 0.08);
    }

    .filter-item-active {
        background-color: rgba(127, 178, 133, 0.15);
    }

    .filter-item-text {
        color: rgb(127, 178, 133);
    }

    .ec-cover {
        background-color: rgb(64, 64, 64);
    }

    .ec-cover-title {
        color: rgb(255, 255, 255);
    }

    .ec-tag {
        background-color: rgba(127, 178, 133, 0.08);
    }

    .ec-tag-text {
        color: rgb(127, 178, 133);
    }

    .ec-location-icon {
        color: rgb(127, 178, 133);
    }

    .ec-location-text {
        color: rgb(127, 178, 133);
    }

    .loading-container {
        background-color: rgb(31, 31, 31);
    }

    .loading-text {
        color: rgb(200, 200, 200);
    }

    .loading-spinner {
        border: 6rpx solid rgb(64, 64, 64);
        border-top: 6rpx solid rgb(127, 178, 133);
    }

    .loading-text {
        color: rgb(127, 178, 133);
    }

    @keyframes spin {
        0% {
            transform: rotate(0deg);
        }
        100% {
            transform: rotate(360deg);
        }
    }
}
